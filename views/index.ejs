<%- include('partials/header') %>

<h4>Agregar Alumno</h4>
<div style="margin-bottom:12px;">
    <input type="text" id="addMatricula" placeholder="Matricula" maxlength="10">
    <input type="text" id="addNombre" placeholder="Nombre">
    <input type="text" id="addDomicilio" placeholder="Domicilio">
    <input type="date" id="addFecha">

    <select id="addSexo">
        <option value="M">M</option>
        <option value="F">F</option>
    </select>

    <!-- NUEVO: STATUS -->
    <select id="addStatus">
        <option value="1">Activo</option>
        <option value="0">Inactivo</option>
    </select>

    <button onclick="agregarAlumno()">Agregar</button>
</div>

<hr>

<h4>Listar Todos</h4>
<button onclick="listarTodos()">Cargar Alumnos</button>

<div id="contenedorTodos" style="display:none; margin-top:12px;">
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Matricula</th>
                <th>Nombre</th>
                <th>Domicilio</th>
                <th>Fecha Nac.</th>
                <th>Sexo</th>
                <th>Status</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="tbodyAlumnos"></tbody>
    </table>
</div>

<hr>

<h4>Buscar por ID</h4>
<input type="number" id="searchId" placeholder="ID">
<button onclick="buscarPorId()">Buscar</button>
<div id="resultBuscarId" style="display:none; margin-top:10px;"></div>

<hr>

<h4>Buscar por Matricula</h4>
<input type="text" id="searchMatricula" placeholder="Matricula">
<button onclick="buscarPorMatricula()">Buscar</button>
<div id="resultBuscarMat" style="display:none; margin-top:10px;"></div>

<hr>

<h4>Actualizar Alumno</h4>
<input type="number" id="updId" placeholder="ID del alumno">
<button onclick="cargarParaActualizar()">Cargar</button>

<div id="updateForm" style="display:none; margin-top:8px;">
    <input type="text" id="updMatricula" placeholder="Matricula">
    <input type="text" id="updNombre" placeholder="Nombre">
    <input type="text" id="updDomicilio" placeholder="Domicilio">
    <input type="date" id="updFecha">

    <select id="updSexo">
        <option value="M">M</option>
        <option value="F">F</option>
    </select>

    <!-- OPCIONAL: también actualizar status -->
    <select id="updStatus">
        <option value="1">Activo</option>
        <option value="0">Inactivo</option>
    </select>

    <button onclick="actualizarAlumno()">Actualizar</button>
</div>

<div id="resultActualizar" style="display:none; margin-top:10px;"></div>

<hr>

<h4>Borrar Alumno</h4>
<input type="number" id="deleteId" placeholder="ID del alumno">
<button onclick="borrarAlumno()">Eliminar</button>
<div id="resultBorrar" style="display:none; margin-top:10px;"></div>

<script>
const API = 'https://manual-dbapi-production.up.railway.app/alumnos';

function statusHTML(status){
    return status == 1 
        ? '<span style="color:green; font-weight:bold;">Activo</span>' 
        : '<span style="color:red; font-weight:bold;">Inactivo</span>';
}

function tablaAlumno(a) {
    var fecha = a.fechanac ? new Date(a.fechanac).toISOString().split('T')[0] : '-';
    return '<table class="table table-bordered">' +
        '<thead class="table-dark"><tr>' +
        '<th>ID</th><th>Matricula</th><th>Nombre</th><th>Domicilio</th>' +
        '<th>Fecha Nac.</th><th>Sexo</th><th>Status</th>' +
        '</tr></thead><tbody><tr>' +
        '<td>' + a.id + '</td>' +
        '<td>' + (a.matricula  || '-') + '</td>' +
        '<td>' + (a.nombre     || '-') + '</td>' +
        '<td>' + (a.domicilio  || '-') + '</td>' +
        '<td>' + fecha + '</td>' +
        '<td>' + (a.sexo       || '-') + '</td>' +
        '<td>' + statusHTML(a.status) + '</td>' +
        '</tr></tbody></table>';
}

async function listarTodos() {
    try {
        var res  = await fetch(API + '/todos');
        var data = await res.json();
        var tbody = document.getElementById('tbodyAlumnos');
        tbody.innerHTML = '';

        data.forEach(function(a) {
            var fecha = a.fechanac ? new Date(a.fechanac).toISOString().split('T')[0] : '-';

            tbody.innerHTML +=
                '<tr>' +
                '<td>' + a.id + '</td>' +
                '<td>' + (a.matricula || '-') + '</td>' +
                '<td>' + (a.nombre    || '-') + '</td>' +
                '<td>' + (a.domicilio || '-') + '</td>' +
                '<td>' + fecha + '</td>' +
                '<td>' + (a.sexo      || '-') + '</td>' +
                '<td>' + statusHTML(a.status) + '</td>' +
                '<td>' +
                    '<button onclick="borrarDesdeTabla(' + a.id + ')">Borrar</button>' +
                '</td>' +
                '</tr>';
        });

        document.getElementById('contenedorTodos').style.display = 'block';

    } catch (err) {
        alert('Error al conectar con la API');
    }
}

async function agregarAlumno() {
    var matricula = document.getElementById('addMatricula').value;
    var nombre    = document.getElementById('addNombre').value;
    var domicilio = document.getElementById('addDomicilio').value;
    var fechanac  = document.getElementById('addFecha').value;
    var sexo      = document.getElementById('addSexo').value;
    var status    = document.getElementById('addStatus').value;

    try {
        var res = await fetch(API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ matricula, nombre, domicilio, fechanac, sexo, status })
        });

        var data = await res.json();
        alert(res.ok ? 'Alumno agregado con ID: ' + data.id : 'Error al agregar');

    } catch (err) {
        alert('Error de conexion');
    }
}

async function borrarDesdeTabla(id) {
    if (!confirm('Eliminar alumno ID ' + id + '?')) return;
    await fetch(API + '/' + id, { method: 'DELETE' });
    listarTodos();
}

async function buscarPorId() {
    var id = document.getElementById('searchId').value;
    if (!id) { alert('Ingresa un ID'); return; }
    try {
        var res  = await fetch(API + '/' + id);
        var div  = document.getElementById('resultBuscarId');
        div.style.display = 'block';
        if (res.ok) {
            var a = await res.json();
            div.innerHTML = tablaAlumno(a);
        } else {
            div.innerHTML = '<p style="color:red;">Alumno no encontrado</p>';
        }
    } catch (err) {
        alert('Error de conexion');
    }
}

async function buscarPorMatricula() {
    var matricula = document.getElementById('searchMatricula').value;
    if (!matricula) { alert('Ingresa una matricula'); return; }
    try {
        var res = await fetch(API + '/matricula/' + matricula);
        var div = document.getElementById('resultBuscarMat');
        div.style.display = 'block';
        if (res.ok) {
            var a = await res.json();
            div.innerHTML = tablaAlumno(a);
        } else {
            div.innerHTML = '<p style="color:red;">Alumno no encontrado</p>';
        }
    } catch (err) {
        alert('Error de conexion');
    }
}

async function borrarAlumno() {
    var id = document.getElementById('deleteId').value;
    if (!id) { alert('Ingresa un ID'); return; }
    if (!confirm('Eliminar alumno ID ' + id + '?')) return;
    try {
        var res  = await fetch(API + '/' + id, { method: 'DELETE' });
        var data = await res.json();
        var div  = document.getElementById('resultBorrar');
        div.style.display = 'block';
        div.innerHTML = res.ok
            ? '<p style="color:green;">' + data.mensaje + '</p>'
            : '<p style="color:red;">Error al eliminar</p>';
    } catch (err) {
        alert('Error de conexion');
    }
}

async function cargarParaActualizar() {
    var id = document.getElementById('updId').value;
    if (!id) { alert('Ingresa un ID'); return; }
    try {
        var res = await fetch(API + '/' + id);
        if (!res.ok) { alert('Alumno no encontrado'); return; }
        var a = await res.json();
        document.getElementById('updMatricula').value = a.matricula  || '';
        document.getElementById('updNombre').value    = a.nombre     || '';
        document.getElementById('updDomicilio').value = a.domicilio  || '';
        document.getElementById('updFecha').value     = a.fechanac ? new Date(a.fechanac).toISOString().split('T')[0] : '';
        document.getElementById('updSexo').value      = a.sexo       || 'M';
        document.getElementById('updStatus').value    = a.status != null ? a.status : 1;
        document.getElementById('updateForm').style.display = 'block';
    } catch (err) {
        alert('Error de conexion');
    }
}

async function actualizarAlumno() {
    var id = document.getElementById('updId').value;
    var datos = {
        matricula: document.getElementById('updMatricula').value,
        nombre:    document.getElementById('updNombre').value,
        domicilio: document.getElementById('updDomicilio').value,
        fechanac:  document.getElementById('updFecha').value,
        sexo:      document.getElementById('updSexo').value,
        status:    document.getElementById('updStatus').value
    };
    try {
        var res  = await fetch(API + '/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(datos)
        });
        var data = await res.json();
        var div  = document.getElementById('resultActualizar');
        div.style.display = 'block';
        div.innerHTML = res.ok
            ? '<p style="color:green;">' + data.mensaje + '</p>'
            : '<p style="color:red;">Error al actualizar</p>';
    } catch (err) {
        alert('Error de conexion');
    }
}
</script>

<%- include('partials/footer') %>
